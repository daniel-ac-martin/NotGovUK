{
  "name": "@not-govuk/summary-list",
  "version": "0.18.1",
  "description": "A component to summarise information, for example, a user’s responses at the end of a form.",
  "type": "module",
  "main": "src/SummaryList.tsx",
  "sass": "assets/SummaryList.scss",
  "exports": {
    ".": {
      "sass": "./assets/SummaryList.scss",
      "default": "./src/SummaryList.tsx"
    }
  },
  "publishConfig": {
    "main": "dist/SummaryList.js",
    "module": "dist/SummaryList.js",
    "typings": "dist/SummaryList.d.ts",
    "exports": {
      ".": {
        "sass": "./assets/SummaryList.scss",
        "types": "./dist/SummaryList.d.ts",
        "import": "./dist/SummaryList.js",
        "default": "./dist/SummaryList.js"
      }
    }
  },
  "files": [
    "/assets",
    "/dist"
  ],
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "prepublishOnly": "npm run clean && npm run build",
    "build": "tsc",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "author": "Daniel A.C. Martin <npm@daniel-martin.co.uk> (http://daniel-martin.co.uk/)",
  "license": "MIT",
  "keywords": [
    "react-components"
  ],
  "dependencies": {
    "@not-govuk/link": "workspace:^",
    "@not-govuk/sass-base": "workspace:^",
    "@react-foundry/anchor-list": "^0.3.0",
    "@react-foundry/component-helpers": "^0.3.0",
    "govuk-frontend": "^6.1.0"
  },
  "peerDependencies": {
    "@react-foundry/docs-components": "^0.3.0",
    "@storybook/addon-docs": "^10.4.0",
    "react": "^19.2.6"
  },
  "peerDependenciesMeta": {
    "@react-foundry/docs-components": {
      "optional": true
    },
    "@storybook/addon-docs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@not-govuk/summary-card": "workspace:*",
    "@not-govuk/visually-hidden": "workspace:*",
    "@react-foundry/component-test-helpers": "0.3.0",
    "@types/react": "19.2.14",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "ts-jest": "29.4.9",
    "typescript": "5.9.3"
  }
}
