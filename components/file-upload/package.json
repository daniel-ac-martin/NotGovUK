{
  "name": "@not-govuk/file-upload",
  "version": "0.18.1",
  "description": "A component to help users select and upload a file.",
  "type": "module",
  "main": "src/FileUpload.tsx",
  "sass": "assets/FileUpload.scss",
  "exports": {
    ".": {
      "sass": "./assets/FileUpload.scss",
      "default": "./src/FileUpload.tsx"
    }
  },
  "publishConfig": {
    "main": "dist/FileUpload.js",
    "module": "dist/FileUpload.js",
    "typings": "dist/FileUpload.d.ts",
    "exports": {
      ".": {
        "sass": "./assets/FileUpload.scss",
        "types": "./dist/FileUpload.d.ts",
        "import": "./dist/FileUpload.js",
        "default": "./dist/FileUpload.js"
      }
    }
  },
  "files": [
    "/assets",
    "/dist"
  ],
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "prepublishOnly": "npm run clean && npm run build",
    "build": "tsc",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "author": "Daniel A.C. Martin <npm@daniel-martin.co.uk> (http://daniel-martin.co.uk/)",
  "license": "MIT",
  "keywords": [
    "react-components"
  ],
  "dependencies": {
    "@not-govuk/form-group": "workspace:^",
    "@not-govuk/input": "workspace:^",
    "@not-govuk/sass-base": "workspace:^",
    "govuk-frontend": "^6.4.0"
  },
  "peerDependencies": {
    "@react-foundry/docs-components": "^0.5.1",
    "@storybook/addon-docs": "^10.5.2",
    "react": "^19.2.7"
  },
  "peerDependenciesMeta": {
    "@react-foundry/docs-components": {
      "optional": true
    },
    "@storybook/addon-docs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@react-foundry/component-test-helpers": "0.5.1",
    "@types/react": "19.2.17",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "ts-jest": "29.4.11",
    "typescript": "5.9.3"
  }
}
