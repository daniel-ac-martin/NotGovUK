{
  "name": "@not-govuk/storybook",
  "version": "0.18.1",
  "description": "Storybook for NotGovUK.",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "serve -l 6006 dist",
    "build": "storybook build -c './src' -o './dist' --stats-json",
    "clean": "rm -rf dist",
    "dev": "storybook dev -c './src' -p 6006",
    "chromatic": "chromatic --exit-zero-on-changes"
  },
  "author": "Daniel A.C. Martin <npm@daniel-martin.co.uk> (http://daniel-martin.co.uk/)",
  "license": "MIT",
  "dependencies": {
    "@not-govuk/components": "workspace:*",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "serve": "14.2.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.2.1",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/react": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "react-router": "7.17.0",
    "sass-embedded": "1.100.0",
    "storybook": "10.4.6",
    "typescript": "5.9.3",
    "vite": "7.3.5"
  }
}
