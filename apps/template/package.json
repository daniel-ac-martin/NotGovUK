{
  "name": "@not-govuk/template",
  "version": "0.18.1",
  "description": "A starting point for writing a new NotGovUK application.",
  "private": true,
  "type": "module",
  "main": "dist/server/index.js",
  "scripts": {
    "start": "node .",
    "start:test": "COOKIES_SECURE=no node .",
    "test": "npm run test:unit",
    "test:ci": "npm test && npm run test:functional:ci",
    "test:functional": "cypress run ${CYPRESS_PROJECT_ID:+--record ${CYPRESS_FLAGS}}",
    "test:functional:ci": "start-server-and-test 'start:test' 'http-get://localhost:8080/readiness' test:functional",
    "test:unit": "jest --passWithNoTests",
    "build": "npm run build:app && npm run build:server",
    "build:app": "react-router build",
    "build:server": "vite -c vite.config.server.ts build",
    "heroku-postbuild": "npm run build",
    "clean": "rm -rf dist/ pkg/ node_modules/.vite/ node_modules/.vite-temp/ .react-router/",
    "dev": "NODE_ENV=development bun --watch --inspect ./src/server/dev.ts",
    "cypress": "cypress open",
    "create": "plop",
    "create:deployment": "plop deployment",
    "create:page": "plop page",
    "typecheck": "react-router typegen && tsc"
  },
  "author": "Daniel A.C. Martin <npm@daniel-martin.co.uk> (http://daniel-martin.co.uk/)",
  "license": "MIT",
  "dependencies": {
    "@mdx-js/rollup": "3.1.1",
    "@not-govuk/components": "workspace:*",
    "@react-foundry/anchor-list": "0.3.0",
    "@react-foundry/fastify": "0.3.0",
    "@react-foundry/fastify-react-router": "0.3.0",
    "@react-foundry/react-router-context": "0.3.0",
    "@react-foundry/router": "0.3.0",
    "@react-router/fs-routes": "7.15.0",
    "@react-router/node": "7.15.0",
    "isbot": "5.1.40",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router": "7.15.0",
    "sass-embedded": "1.99.0",
    "serverless-http": "4.0.0"
  },
  "peerDependencies": {
    "@react-foundry/user-info": "^0.3.0"
  },
  "devDependencies": {
    "@react-foundry/app-plop-pack": "0.3.0",
    "@react-foundry/vite-html-react": "0.3.0",
    "@react-router/dev": "7.15.0",
    "@types/mdx": "2.0.13",
    "@types/node": "24.12.4",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "bun": "1.3.13",
    "cypress": "15.14.2",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "start-server-and-test": "3.0.2",
    "ts-jest": "29.4.9",
    "typescript": "5.9.3",
    "vite": "7.3.3"
  }
}
