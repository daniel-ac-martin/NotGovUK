{
  "name": "@not-govuk/react-router-example",
  "version": "0.18.1",
  "description": "A React Router Framework application with NotGovUK components.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./dist/server/index.js",
    "test": "npm run test:unit",
    "test:ci": "npm test && npm run test:functional:ci",
    "test:functional": "cypress run ${CYPRESS_PROJECT_ID:+--record ${CYPRESS_FLAGS}}",
    "test:functional:ci": "start-server-and-test 'start' 'http-get://localhost:3000/' test:functional",
    "test:unit": "jest --passWithNoTests",
    "clean": "rm -rf dist",
    "cypress": "cypress open",
    "typecheck": "react-router typegen && tsc"
  },
  "author": "Daniel A.C. Martin <npm@daniel-martin.co.uk> (http://daniel-martin.co.uk/)",
  "license": "MIT",
  "dependencies": {
    "@not-govuk/components": "workspace:*",
    "@react-router/fs-routes": "7.16.0",
    "@react-router/node": "7.16.0",
    "@react-router/serve": "7.16.0",
    "isbot": "5.1.40",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "7.16.0"
  },
  "devDependencies": {
    "@react-router/dev": "7.16.0",
    "@types/node": "24.12.4",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "cypress": "15.16.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "sass-embedded": "1.100.0",
    "start-server-and-test": "3.0.8",
    "ts-jest": "29.4.11",
    "typescript": "5.9.3",
    "vite": "7.3.5"
  }
}
